{
  "name": "prono-cdm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "wrangler dev worker/src/index.ts --local --persist-to .wrangler/state",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy:api": "wrangler deploy",
    "d1:migrate:local": "wrangler d1 migrations apply prono-cdm --local",
    "d1:migrate:remote": "wrangler d1 migrations apply prono-cdm --remote"
  },
  "dependencies": {
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260603.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.15",
    "wrangler": "^4.54.0"
  }
}
